#
# nginx dual-role config:
#   - Inbound reverse proxy (port 19000 HTTPS + port 80 ACME) — terminates TLS
#     for external clients reaching OpenClaw; certs managed by ngx_http_acme_module.
#   - Outbound forward proxy (port 8080) — CONNECT tunnel for HTTPS, plain proxy
#     for HTTP; openclaw routes all external traffic here via HTTP_PROXY/HTTPS_PROXY.
#     nginx sees destination host:port for HTTPS but does NOT decrypt content.
#
# Template variables substituted at startup: $BACKEND_HOST, $BACKEND_PORT,
# $ACME_DOMAIN, $ACME_EMAIL

load_module modules/ngx_otel_module.so;
load_module modules/ngx_http_acme_module.so;

events {
    worker_connections 1024;
}

http {
    # Required by nginx-acme for DNS lookups during ACME protocol exchanges
    resolver 1.1.1.1 8.8.8.8 valid=300s ipv6=off;
    resolver_timeout 5s;

    # ── ACME issuer (Let's Encrypt) ────────────────────────────────────────────
    acme_issuer letsencrypt {
        uri        https://acme-v02.api.letsencrypt.org/directory;
        contact    ${ACME_EMAIL};
        state_path /var/cache/nginx/acme-letsencrypt;
        accept_terms_of_service;
    }

    # Shared memory zone for coordinating cert state across worker processes
    acme_shared_zone zone=ngx_acme_shared:1M;

    # ── OTel exporter (gRPC to otel-collector) ─────────────────────────────────
    otel_exporter {
        endpoint otel-collector:4317;
    }

    # ── Logging ────────────────────────────────────────────────────────────────
    access_log /dev/stdout;
    error_log  /dev/stderr warn;

    # ── Upstream: backend service ──────────────────────────────────────────────
    upstream backend {
        server ${BACKEND_HOST}:${BACKEND_PORT};
        keepalive 32;
    }

    # ── HTTPS server ───────────────────────────────────────────────────────────
    server {
        listen 19000 ssl;
        server_name ${ACME_DOMAIN};

        # nginx-acme manages the certificate for this domain
        acme_certificate letsencrypt;

        ssl_certificate       $acme_certificate;
        ssl_certificate_key   $acme_certificate_key;
        # Avoid parsing the certificate object on every request
        ssl_certificate_cache max=2;

        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;
        ssl_session_cache   shared:SSL:10m;
        ssl_session_timeout 10m;

        # Emit one OTel span per inbound request
        otel_trace         on;
        otel_trace_context propagate;
        otel_span_name     "inbound.request";

        location / {
            proxy_pass         http://backend;
            proxy_http_version 1.1;
            proxy_set_header   Upgrade         $http_upgrade;
            proxy_set_header   Connection      "upgrade";
            proxy_set_header   Host            $host;
            proxy_set_header   X-Real-IP       $remote_addr;
            proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;

            # Per-request span attributes
            otel_span_attr http.client_ip  $remote_addr;
            otel_span_attr http.method     $request_method;
            otel_span_attr http.path       $request_uri;
            otel_span_attr http.status     $status;
        }
    }

    # ── HTTP server — required for ACME HTTP-01 challenge ──────────────────────
    # nginx-acme intercepts /.well-known/acme-challenge/ requests automatically.
    server {
        listen 80;
        server_name ${ACME_DOMAIN};

        location / {
            return 404;
        }
    }

    # ── Forward proxy (outbound HTTP from openclaw) ───────────────────────────
    # openclaw routes all external traffic here via HTTP_PROXY / HTTPS_PROXY.
    # HTTP requests: proxied in full — host, method, status visible to nginx.
    # HTTPS requests: Node.js sends HTTP CONNECT; nginx returns 405 (no CONNECT
    #   support in stock 1.31.0-otel). Outbound HTTPS isolation is enforced by
    #   iptables inside the openclaw container — direct internet access is blocked
    #   at the kernel level regardless.
    #
    # TODO: HTTPS CONNECT tunneling requires ngx_http_proxy_connect_module, which
    #   does not yet patch cleanly against nginx 1.31.0 source. Track upstream
    #   and re-enable when a compatible patch is available.
    #
    # Access control for HTTP: by default all destinations are permitted.
    # To restrict, uncomment and extend:
    #
    # map $host $proxy_allowed {
    #     default              0;
    #     ~*\.openai\.com      1;
    #     ~*\.anthropic\.com   1;
    # }
    #
    # Then inside location /: if ($proxy_allowed = 0) { return 403; }
    server {
        listen 8080;
        resolver 1.1.1.1 8.8.8.8 valid=300s ipv6=off;
        resolver_timeout 5s;

        otel_trace         on;
        otel_trace_context propagate;

        location / {
            proxy_pass         http://$http_host$request_uri;
            proxy_set_header   Host $http_host;

            otel_span_name     "outbound.request";
            otel_span_attr     outbound.host   $http_host;
            otel_span_attr     outbound.method $request_method;
            otel_span_attr     outbound.status $status;
        }
    }
}
